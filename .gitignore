  ]
};



server.js


const express = require("express");
const app = express();

let players = [];

app.get("/leaderboard", (req, res) => {

  const sorted = players.sort((a,b)=>b.trophies-a.trophies);

  res.json(sorted);

});

app.listen(3000, () => {
  console.log("Server läuft");
});


