  { rank: 1, trophies: 0 },
  { rank: 2, trophies: 10 },
  { rank: 3, trophies: 20 },
  { rank: 4, trophies: 30 },
  { rank: 5, trophies: 40 },
  { rank: 6, trophies: 60 },
  { rank: 7, trophies: 80 },
  { rank: 8, trophies: 100 },
