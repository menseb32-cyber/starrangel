index.html
<!DOCTYPE html>
<html>
<head>
<title>Mini Brawler</title>

<style>

body{
background:#1e1e1e;
color:white;
font-family:Arial;
text-align:center;
}

#game{
width:600px;
height:400px;
background:#2b2b2b;
margin:auto;
position:relative;
overflow:hidden;
}

.player{
width:30px;
height:30px;
background:purple;
position:absolute;
border-radius:50%;
}

.bot{
width:30px;
height:30px;
background:red;
position:absolute;
border-radius:50%;
}

</style>
</head>

<body>

<h1>Mini Brawler</h1>

<button onclick="startGame()">Start</button>

<div id="game"></div>

<script src="game.js"></script>

</body>
</html>


game.js

let player
let bot

function startGame(){

const game=document.getElementById("game")

game.innerHTML=""

player=document.createElement("div")
player.className="player"
player.style.left="50px"
player.style.top="200px"

bot=document.createElement("div")
bot.className="bot"
bot.style.left="500px"
bot.style.top="200px"

game.appendChild(player)
game.appendChild(bot)

}

document.addEventListener("keydown",function(e){

let x=parseInt(player.style.left)
let y=parseInt(player.style.top)

if(e.key=="w") y-=10
if(e.key=="s") y+=10
if(e.key=="a") x-=10
if(e.key=="d") x+=10

player.style.left=x+"px"
player.style.top=y+"px"

checkFight()

})

function checkFight(){

let px=parseInt(player.style.left)
let bx=parseInt(bot.style.left)

if(Math.abs(px-bx)<30){

alert("Bot besiegt!")

}

}




game.js

const player = {
  x: 100,
  y: 200,
  hp: 5600,
  damage: 1500,
  trophies: 0,
  cubes: 0
};

const bot = {
  x: 400,
  y: 200,
  hp: 5000
};

function movePlayer(dx, dy) {
  player.x += dx;
  player.y += dy;
}

function attackBot() {
  bot.hp -= player.damage;

  if (bot.hp <= 0) {
    player.trophies += 8;
    console.log("Bot besiegt!");
    respawnBot();
  }
}

function respawnBot() {
  bot.hp = 5000;
  bot.x = Math.random() * 500;
  bot.y = Math.random() * 300;
}


const cubes = [];

function spawnCube() {
  cubes.push({
    x: Math.random() * 500,
    y: Math.random() * 300
  });
}

function collectCube(index) {
  player.cubes++;
  player.damage += 200;
  player.hp += 400;
  cubes.splice(index, 1);
}


const ranks = [
  { rank: 1, trophies: 0 },
  { rank: 5, trophies: 40 },
  { rank: 10, trophies: 140 },
  { rank: 15, trophies: 240 },
  { rank: 20, trophies: 400 },
  { rank: 25, trophies: 650 },
  { rank: 30, trophies: 900 },
  { rank: 35, trophies: 1150 }
];

function getRank(trophies) {
  let rank = 1;

  ranks.forEach(r => {
    if (trophies >= r.trophies) {
      rank = r.rank;
    }
  });

  return rank;
}


function openStarDrop() {

  let chance = Math.random() * 100;

  if (chance < 1) return "Legendary";
  if (chance < 10) return "Epic";
  if (chance < 40) return "Rare";

  return "Common";
}


const brawlPass = {
  season: 1,
  purchasable: false,

  freeTrack: [
    { tier: 1, reward: "Coins 50" },
