game.js

const player = {
  x: 100,
  y: 200,
  hp: 5600,
  damage: 1500,
  trophies: 0,
  cubes: 0
};

const bot = {
  x: 400,
  y: 200,
  hp: 5000
};

function movePlayer(dx, dy) {
  player.x += dx;
  player.y += dy;
}

function attackBot() {
  bot.hp -= player.damage;

  if (bot.hp <= 0) {
    player.trophies += 8;
    console.log("Bot besiegt!");
    respawnBot();
  }
}

function respawnBot() {
  bot.hp = 5000;
  bot.x = Math.random() * 500;
  bot.y = Math.random() * 300;
}


const cubes = [];

function spawnCube() {
  cubes.push({
    x: Math.random() * 500,
    y: Math.random() * 300
  });
}

function collectCube(index) {
  player.cubes++;
  player.damage += 200;
  player.hp += 400;
  cubes.splice(index, 1);
}


const ranks = [
  { rank: 1, trophies: 0 },
  { rank: 5, trophies: 40 },
  { rank: 10, trophies: 140 },
  { rank: 15, trophies: 240 },
  { rank: 20, trophies: 400 },
  { rank: 25, trophies: 650 },
  { rank: 30, trophies: 900 },
  { rank: 35, trophies: 1150 }
];

function getRank(trophies) {
  let rank = 1;

  ranks.forEach(r => {
    if (trophies >= r.trophies) {
      rank = r.rank;
    }
  });

  return rank;
}


function openStarDrop() {

  let chance = Math.random() * 100;

  if (chance < 1) return "Legendary";
  if (chance < 10) return "Epic";
  if (chance < 40) return "Rare";

  return "Common";
}


