function giveGems(playerID, amount) {

  if(players[playerID]){

    players[playerID].gems += amount;

    console.log(playerID + " hat jetzt " + players[playerID].gems + " Gems");

  } else {

    console.log("Spieler nicht gefunden");

  }

}



